# OpenAI API configuration
OPENAI_API_KEY={api_key}
OPENAI_BASE_URL={base_url}
OPENAI_MODEL={model}
OPENAI_TIMEOUT=60.0
OPENAI_TEMPERATURE=0.7


# Agent configuration
FOX_AGENT_PLAN_MODE=auto
FOX_AGENT_MEMORY_MODE=auto
FOX_AGENT_RETRIEVAL_MODE=auto
FOX_AGENT_KNOWLEDGE_BASE_PATH=./docs
FOX_AGENT_RETRIEVAL_TOP_K=5
FOX_AGENT_CHUNK_SIZE=1000
FOX_AGENT_CHUNK_OVERLAP=200