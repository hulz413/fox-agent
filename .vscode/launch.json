{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Chat",
            "type": "debugpy",
            "request": "launch",
            "module": "src",
            "args": [
                "-p",
                "'What is the codename of the project'",
                "--retrieval-mode",
                "auto"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        },
        {
            "name": "Python Debugger: Ingest",
            "type": "debugpy",
            "request": "launch",
            "module": "src",
            "args": [
                "--ingest",
                "./src"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        },
        {
            "name": "Python Debugger: Eval",
            "type": "debugpy",
            "request": "launch",
            "module": "src",
            "args": [
                "--eval",
                "./examples/rag_eval.jsonl"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        }
    ]
}